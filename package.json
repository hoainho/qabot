{
  "name": "@nhonh/qabot",
  "version": "1.0.1",
  "description": "AI-powered universal QA automation tool. Import any project, AI analyzes and runs tests across all layers.",
  "main": "src/index.js",
  "bin": {
    "qabot": "bin/qabot.js"
  },
  "type": "module",
  "scripts": {
    "start": "node bin/qabot.js",
    "dev": "node --watch bin/qabot.js",
    "test": "node --test tests/core/*.test.js tests/executor/*.test.js tests/runners/*.test.js tests/analyzers/*.test.js tests/ai/*.test.js tests/reporter/*.test.js",
    "lint": "eslint src/",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "qa",
    "testing",
    "automation",
    "ai",
    "playwright",
    "jest",
    "vitest",
    "e2e",
    "unit-test",
    "test-runner",
    "test-report",
    "cli"
  ],
  "author": "Hoài Nhớ <nhoxtvt@gmail.com> (https://github.com/hoainho)",
  "license": "MIT",
  "homepage": "https://hoainho.github.io/qabot",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hoainho/qabot.git"
  },
  "bugs": {
    "url": "https://github.com/hoainho/qabot/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "cosmiconfig": "^9.0.0",
    "enquirer": "^2.4.1",
    "glob": "^11.0.0",
    "handlebars": "^4.7.8",
    "nanoid": "^5.0.9",
    "ora": "^8.1.1",
    "strip-ansi": "^7.1.0",
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "eslint": "^9.0.0"
  },
  "files": [
    "bin/",
    "src/",
    "templates/"
  ]
}
